---
const year = new Date().getFullYear()

const links = [
  { href: 'mailto:contacto@elmanueh.es', label: 'Email' },
  { href: 'https://github.com/elmanueh', label: 'GitHub' },
  { href: 'https://www.linkedin.com/in/elmanueh', label: 'LinkedIn' }
]
---

<footer class="mt-20">
  <div
    class="mx-auto flex max-w-4xl flex-col gap-6 px-6 py-10 sm:flex-row sm:items-center sm:justify-between"
  >
    <p class="text-sm font-medium text-foreground">
      © {year} Manuel Bernabé Rodríguez <span class="text-muted-foreground"
        >(elmanueh)</span
      >
    </p>

    <div class="flex items-center gap-6 text-sm">
      {
        links.map(({ href, label }) => (
          <a
            href={href}
            target="_blank"
            rel="noreferrer"
            class="text-muted-foreground transition-colors hover:text-foreground"
          >
            {label}
          </a>
        ))
      }
    </div>
  </div>
</footer>
