---
import ClanInfo from '@/components/clashofclans/clan-info.astro'
import ClanSearch from '@/components/clashofclans/clan-search.astro'
import Layout from '@/layouts/layout.astro'
---

<Layout>
  <section class="pt-20 pb-16">
    <header class="flex flex-col items-center gap-10 pb-12">
      <p class="text-4xl font-bold text-purple-300">Clash Of Clans</p>
      <ClanSearch />
    </header>

    <ClanInfo />
  </section>

  <script>
    import type { PlayerClan } from '@/types/player-clan'

    type PlayerColumn = keyof PlayerClan
    type PlayerValue = PlayerClan[PlayerColumn]

    const rename: Record<string, string> = {
      player: 'Id',
      name: 'Nombre',
      role: 'Rango',
      townHall: 'TH',
      lootCapital: 'Capital +',
      addCapital: 'Capital -',
      clanGames: 'Juegos',
      warPreference: 'Guerra',
      warAttacks: 'Guerra Atq.',

      member: 'Miembro',
      admin: 'Veterano',
      coLeader: 'Colíder',
      leader: 'Líder',

      in: 'Si',
      out: 'No'
    }

    const clanTagInput = document.querySelector<HTMLInputElement>('#coc-tag')
    const searchButton =
      document.querySelector<HTMLButtonElement>('#coc-search')
    const results = document.querySelector<HTMLDivElement>('#coc-results')

    function compareValues(left: PlayerValue, right: PlayerValue) {
      if (typeof left === 'number' && typeof right === 'number') {
        return left > right ? 1 : -1
      }

      return String(left) > String(right) ? 1 : -1
    }

    function renderRows(
      tbody: HTMLTableSectionElement,
      players: PlayerClan[]
    ) {
      tbody.replaceChildren()

      players.forEach((player, index) => {
        const row = document.createElement('tr')
        row.className = 'bg-gray-600 even:bg-gray-500'

        const position = document.createElement('td')
        position.className = 'px-3 py-2 font-medium'
        position.textContent = String(index + 1)
        row.append(position)

        Object.values(player).forEach((value) => {
          const cell = document.createElement('td')
          cell.className = 'px-3'
          cell.textContent = rename[String(value)] ?? String(value)
          row.append(cell)
        })

        tbody.append(row)
      })
    }

    function renderTable(players: PlayerClan[]) {
      if (!results) return

      results.replaceChildren()
      if (players.length === 0) return

      const originalPlayers = players.slice()
      const columnSorted: Partial<Record<PlayerColumn, boolean>> = {}
      const columns = Object.keys(players[0]) as PlayerColumn[]

      const wrapper = document.createElement('div')
      wrapper.className = 'overflow-x-auto'

      const table = document.createElement('table')
      table.className = 'm-0 min-w-full text-center'

      const thead = document.createElement('thead')
      const headerRow = document.createElement('tr')
      const positionHeader = document.createElement('th')
      positionHeader.className = 'bg-gray-700 py-2 text-md text-white'
      headerRow.append(positionHeader)

      const tbody = document.createElement('tbody')

      columns.forEach((column) => {
        const header = document.createElement('th')
        header.className =
          'cursor-pointer bg-gray-700 px-3 py-2 text-md text-white hover:text-purple-300'
        header.textContent = rename[column]

        header.addEventListener('click', () => {
          const sortedPlayers = originalPlayers.slice()

          if (columnSorted[column] === true) {
            sortedPlayers.sort((a, b) => compareValues(a[column], b[column]))
            columnSorted[column] = false
          } else {
            sortedPlayers.sort((a, b) => compareValues(b[column], a[column]))
            columnSorted[column] = true
          }

          renderRows(tbody, sortedPlayers)
        })

        headerRow.append(header)
      })

      thead.append(headerRow)
      table.append(thead, tbody)
      wrapper.append(table)
      results.append(wrapper)
      renderRows(tbody, originalPlayers)
    }

    async function handlePlayers(clanTag: string) {
      try {
        const response = await fetch(
          `https://elmanueh.es/v1/clans/clan/${encodeURIComponent(clanTag)}`
        )

        if (response.status !== 200) {
          throw new Error('Failed to fetch clan data')
        }

        const players = (await response.json()) as PlayerClan[]
        renderTable(players)
      } catch (error) {
        console.log(error)
        results?.replaceChildren()
      }
    }

    searchButton?.addEventListener('click', () => {
      handlePlayers(clanTagInput?.value ?? '')
    })
  </script>
</Layout>
